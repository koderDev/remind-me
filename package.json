{
  "name": "remind-me",
  "displayName": "remindMe",
  "description": "helps you set reminders for upcoming tasks.",
  "version": "1.0.0",
  "publisher":"koderDev",
  "icon":"img/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/koderDev/remind-me.git"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands":[
      {
        "command":"extension.removeResidue",
        "title":"remindMe: Remove all reminder residue lines"
      },
      {
        "command": "extension.deleteReminders",
        "title":"remindMe: Manage/Delete active reminders"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
